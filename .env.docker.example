APP_NAME="Material Inspection Recording System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mirs.hiblow.online
APP_PORT=8080
ASSET_URL=
VITE_APP_URL=https://mirs.hiblow.online
APPROVALS_ENABLED=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=fc_1_data_db_testing
DB_USERNAME=hpi.python
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.hiblow.online
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=mirs.hiblow.online

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_PUSHER_APP_KEY=
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_CLUSTER=mt1
