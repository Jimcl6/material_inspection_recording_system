APP_NAME="Material Inspection Recording System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
MIRS_INTERNAL_HOST=mirs.internal.example
APP_URL=https://${MIRS_INTERNAL_HOST}
APP_PORT=8080
ASSET_URL=
VITE_APP_URL=${APP_URL}
APPROVALS_ENABLED=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=mirs
DB_USERNAME=mirs_app
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=${MIRS_INTERNAL_HOST}
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
CORS_ALLOWED_ORIGINS=${APP_URL}
SANCTUM_STATEFUL_DOMAINS=${MIRS_INTERNAL_HOST}

# Set to the exact reverse-proxy IP address or CIDR used by this deployment.
TRUSTED_PROXIES=

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_PUSHER_APP_KEY=
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_CLUSTER=mt1
